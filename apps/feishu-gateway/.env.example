TFCLAW_CONFIG_PATH=./config.json
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
TFCLAW_TOKEN=demo-token
TFCLAW_RELAY_URL=ws://127.0.0.1:8787
FEISHU_ALLOW_FROM=
TFCLAW_FEISHU_DISABLE_PROXY=true
TFCLAW_NEXCHATBOT_ENABLED=false
TFCLAW_NEXCHATBOT_BASE_URL=http://127.0.0.1:8094
TFCLAW_NEXCHATBOT_RUN_PATH=/v1/main-agent/feishu-bridge
TFCLAW_NEXCHATBOT_API_KEY=
TFCLAW_NEXCHATBOT_TIMEOUT_MS=90000
TFCLAW_OPENCLAW_ENABLED=false
TFCLAW_OPENCLAW_ROOT=../openclaw
TFCLAW_OPENCLAW_STATE_DIR=.runtime/openclaw_bridge
TFCLAW_OPENCLAW_SHARED_SKILLS_DIR=../openclaw/skills
TFCLAW_OPENCLAW_USER_HOME_ROOT=.home
TFCLAW_OPENCLAW_USER_PREFIX=tfoc_
TFCLAW_OPENCLAW_TMUX_SESSION_PREFIX=tfoc-
TFCLAW_OPENCLAW_GATEWAY_HOST=127.0.0.1
TFCLAW_OPENCLAW_GATEWAY_PORT_BASE=19000
TFCLAW_OPENCLAW_GATEWAY_PORT_MAX=19999
TFCLAW_OPENCLAW_STARTUP_TIMEOUT_MS=45000
TFCLAW_OPENCLAW_REQUEST_TIMEOUT_MS=180000
TFCLAW_OPENCLAW_SESSION_KEY=main
TFCLAW_OPENCLAW_NODE_PATH=/usr/bin/node
TFCLAW_OPENCLAW_CONFIG_TEMPLATE_PATH=
TFCLAW_OPENCLAW_AUTO_BUILD_DIST=false
TFCLAW_OPENCLAW_ALLOW_AUTO_CREATE_USER=true
